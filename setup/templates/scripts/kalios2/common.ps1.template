Set-StrictMode -Version Latest
$ErrorActionPreference = "Stop"

function Get-ReactRoot { return (Resolve-Path (Join-Path $PSScriptRoot "..\..")).Path }

function Get-ComposeFile {
    param([string]$Root)
    foreach ($name in @("docker-compose.yml", "docker-compose.yaml", "compose.yml", "compose.yaml")) {
        $path = Join-Path $Root $name
        if (Test-Path $path) { return (Resolve-Path $path).Path }
    }
    throw "No Docker Compose file found in $Root"
}

function Find-CoreRoot {
    param([string]$RequestedRoot, [string]$ReactRoot)
    $candidates = @()
    if ($RequestedRoot) { $candidates += $RequestedRoot }
    if ($env:KALIOS2_ROOT) { $candidates += $env:KALIOS2_ROOT }
    $parent = Split-Path $ReactRoot -Parent
    $candidates += @((Join-Path $parent "KaliOS2"), (Join-Path $parent "kali-os"), "S:\AI\KaliOS2", "S:\AI\kali-os")
    foreach ($candidate in ($candidates | Select-Object -Unique)) {
        if (-not $candidate -or -not (Test-Path $candidate)) { continue }
        try {
            $root = (Resolve-Path $candidate).Path
            [void](Get-ComposeFile -Root $root)
            return $root
        } catch { }
    }
    return $null
}

function Test-DockerReady {
    if (-not (Get-Command docker -ErrorAction SilentlyContinue)) { return $false }
    & docker info *> $null
    return $LASTEXITCODE -eq 0
}

function Invoke-Compose {
    param([string]$Root, [string]$ComposeFile, [string[]]$Arguments)
    $args = @("compose", "--project-directory", $Root, "-f", $ComposeFile)
    $envFile = Join-Path $Root ".env"
    if (Test-Path $envFile) { $args += @("--env-file", $envFile) }
    $args += $Arguments
    & docker @args
    if ($LASTEXITCODE -ne 0) { throw "Docker Compose failed in $Root." }
}

function Ensure-EnvFile {
    param([string]$Root)
    $path = Join-Path $Root ".env"
    if (-not (Test-Path $path)) {
        $example = Join-Path $Root ".env.example"
        if (Test-Path $example) { Copy-Item $example $path } else { New-Item -ItemType File -Path $path | Out-Null }
    }
    return $path
}

function Get-EnvValue {
    param([string]$Path, [string]$Name)
    if (-not (Test-Path $Path)) { return $null }
    $pattern = "^\s*" + [regex]::Escape($Name) + "\s*=\s*(.*)$"
    foreach ($line in Get-Content -LiteralPath $Path) {
        if ($line -match $pattern) { return $Matches[1].Trim().Trim('"').Trim("'") }
    }
    return $null
}

function Set-EnvValue {
    param([string]$Path, [string]$Name, [string]$Value)
    $lines = if (Test-Path $Path) { @(Get-Content -LiteralPath $Path) } else { @() }
    $pattern = "^\s*" + [regex]::Escape($Name) + "\s*="
    $seen = $false
    $output = foreach ($line in $lines) {
        if ($line -match $pattern) {
            if (-not $seen) { "$Name=$Value" }
            $seen = $true
        } else { $line }
    }
    if (-not $seen) { $output += "$Name=$Value" }
    Set-Content -LiteralPath $Path -Value $output -Encoding UTF8
}

function New-RandomValue {
    $bytes = New-Object byte[] 48
    $provider = [System.Security.Cryptography.RandomNumberGenerator]::Create()
    try { $provider.GetBytes($bytes) } finally { $provider.Dispose() }
    return [Convert]::ToBase64String($bytes).TrimEnd('=').Replace('+','-').Replace('/','_')
}

function Ensure-ExternalNetwork {
    & docker network inspect kalios2-net *> $null
    if ($LASTEXITCODE -ne 0) { & docker network create kalios2-net | Out-Null }
}

function Connect-CoreContainers {
    foreach ($name in @("kalios2-hermes", "kalios2-ollama", "kalios2-webui")) {
        & docker inspect $name *> $null
        if ($LASTEXITCODE -ne 0) { continue }
        & docker network connect kalios2-net $name *> $null
    }
}

function Test-Url {
    param([string]$Url)
    try {
        $response = Invoke-WebRequest -Uri $Url -UseBasicParsing -TimeoutSec 8
        return @{ ok = ($response.StatusCode -ge 200 -and $response.StatusCode -lt 400); detail = "HTTP $($response.StatusCode)" }
    } catch { return @{ ok = $false; detail = $_.Exception.Message } }
}

function Get-ContainerStatus {
    $items = @()
    foreach ($name in @("kalios2-hermes", "kalios2-ollama", "kalios2-webui", "kalios2-react")) {
        $state = "missing"; $health = $null
        try {
            $raw = & docker inspect $name 2>$null
            if ($LASTEXITCODE -eq 0 -and $raw) {
                $container = ($raw | ConvertFrom-Json)[0]
                $state = [string]$container.State.Status
                if ($container.State.Health) { $health = [string]$container.State.Health.Status }
            }
        } catch { }
        $items += @{ name = $name; state = $state; health = $health }
    }
    return $items
}

function New-Step {
    param([string]$Key, [string]$Label)
    return @{ key = $Key; label = $Label; state = "pending"; detail = ""; startedAt = $null; finishedAt = $null }
}

function New-Status {
    param([string]$Mode, [string]$Script, [array]$Steps)
    return @{ version = 1; updatedAt = (Get-Date).ToUniversalTime().ToString("o"); mode = $Mode; state = "running"; runningScript = $Script; currentStep = $null; message = "Starting"; steps = $Steps; checks = @(); containers = @(); dockerRunning = $false; networkExists = $false }
}

function Set-StepState {
    param([hashtable]$Status, [string]$Key, [string]$State, [string]$Detail = "")
    $step = $Status.steps | Where-Object { $_.key -eq $Key } | Select-Object -First 1
    if (-not $step) { return }
    $step.state = $State; $step.detail = $Detail
    if ($State -eq "running") { $step.startedAt = (Get-Date).ToUniversalTime().ToString("o"); $Status.currentStep = $step.label }
    if ($State -in @("success", "warning", "failed", "skipped")) { $step.finishedAt = (Get-Date).ToUniversalTime().ToString("o") }
}

function Save-Status {
    param([string]$ReactRoot, [hashtable]$Status)
    $directory = Join-Path $ReactRoot "runtime\kalios2"
    if (-not (Test-Path $directory)) { New-Item -ItemType Directory -Path $directory -Force | Out-Null }
    $Status.updatedAt = (Get-Date).ToUniversalTime().ToString("o")
    $Status.dockerRunning = Test-DockerReady
    $Status.containers = @(Get-ContainerStatus)
    & docker network inspect kalios2-net *> $null
    $Status.networkExists = $LASTEXITCODE -eq 0
    $path = Join-Path $directory "setup-status.json"
    $temp = "$path.tmp"
    $Status | ConvertTo-Json -Depth 8 | Set-Content -LiteralPath $temp -Encoding UTF8
    Move-Item -LiteralPath $temp -Destination $path -Force
}

function Finish-Status {
    param([hashtable]$Status, [string]$State, [string]$Message)
    $Status.state = $State; $Status.message = $Message; $Status.currentStep = $null; $Status.runningScript = $null
}

function Confirm-ManualStep {
    param([switch]$Interactive, [string]$Label)
    if ($Interactive) { [void](Read-Host "Press ENTER to run: $Label") }
}
