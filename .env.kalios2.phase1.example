# KaliOS2 Phase 1 integration configuration
# Copy the required values into the environment used to start the server.
# Never commit real tokens.

# When KaliOS2 runs in the same Docker network as the KALI stack:
KALIOS2_HERMES_URL=http://kali-hermes:8000
KALIOS2_OLLAMA_URL=http://kali-ollama:11434
KALIOS2_QDRANT_URL=http://kali-qdrant:6333
KALIOS2_OBSIDIAN_URL=http://kali-obsidian:3000
KALIOS2_OPENWEBUI_URL=http://kali-open-webui:8080

# When KaliOS2 runs directly on the host, use the published ports instead:
# KALIOS2_HERMES_URL=http://127.0.0.1:8000
# KALIOS2_OLLAMA_URL=http://127.0.0.1:11434
# KALIOS2_QDRANT_URL=http://127.0.0.1:6333
# KALIOS2_OBSIDIAN_URL=http://127.0.0.1:3001
# KALIOS2_OPENWEBUI_URL=http://127.0.0.1:3000

# Hermes OpenAI-compatible chat endpoint
KALIOS2_HERMES_MODEL=hermes
KALIOS2_HERMES_TOKEN=
# KALI_INTERNAL_TOKEN can be used instead of KALIOS2_HERMES_TOKEN.

# Browser-facing links shown by Connections and KALI Brain
KALIOS2_HERMES_PUBLIC_URL=http://127.0.0.1:8000
KALIOS2_OLLAMA_PUBLIC_URL=http://127.0.0.1:11434
KALIOS2_QDRANT_PUBLIC_URL=http://127.0.0.1:6333
KALIOS2_OBSIDIAN_PUBLIC_URL=http://127.0.0.1:3001
KALIOS2_OPENWEBUI_PUBLIC_URL=http://127.0.0.1:3000

# Optional health paths
KALIOS2_HERMES_HEALTH_PATH=/health
KALIOS2_OLLAMA_HEALTH_PATH=/api/tags
KALIOS2_QDRANT_HEALTH_PATH=/readyz
KALIOS2_OBSIDIAN_HEALTH_PATH=/
KALIOS2_OPENWEBUI_HEALTH_PATH=/health
KALIOS2_PROBE_TIMEOUT_MS=4000

# Doctor command target
KALIOS2_BASE_URL=http://127.0.0.1:3100
# KALIOS2_COOKIE=only-needed-for-authenticated-deployments
