DATABASE_URL=postgres://paperclip:paperclip@localhost:5432/paperclip
PORT=3100
SERVE_UI=false
BETTER_AUTH_SECRET=replace-with-a-long-random-secret

# KaliOS2 Phase 1 control plane.
# Use container DNS names when KaliOS React joins the external kalios2-net network.
KALIOS2_HERMES_URL=http://kalios2-hermes:8642
KALIOS2_HERMES_TOKEN=replace-with-the-HERMES_API_KEY-from-KaliOS2
KALIOS2_HERMES_MODEL=hermes
KALIOS2_HERMES_PUBLIC_URL=http://127.0.0.1:9119
KALIOS2_OLLAMA_URL=http://kalios2-ollama:11434
KALIOS2_OLLAMA_PUBLIC_URL=http://127.0.0.1:11434
KALIOS2_OPENWEBUI_URL=http://kalios2-webui:8080
KALIOS2_OPENWEBUI_PUBLIC_URL=http://127.0.0.1:3000
KALIOS2_PROBE_TIMEOUT_MS=4000

# Phase 2 services remain disabled until explicitly configured.
KALIOS2_QDRANT_URL=disabled
KALIOS2_OBSIDIAN_URL=disabled

# Discord webhook for daily merge digest (scripts/discord-daily-digest.sh)
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
